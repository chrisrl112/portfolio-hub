---
import BaseLayout from '@layouts/BaseLayout.astro';
import StatusBadge from '@components/StatusBadge.astro';
import ManifestPanel from '@components/ManifestPanel.astro';
import {
  getHeartbeat,
  getProjects,
  metricsWithValues,
  type Manifest,
} from '@lib/manifests';
import { fetchHeartbeats, withHeartbeat } from '@lib/heartbeats';
// MaturityMeter renders inside StatusBadge; metrics render only when values
// exist (else the heartbeat line shows "awaiting first report").

export async function getStaticPaths() {
  // Build-time heartbeat feed (ph-5): merge live telemetry onto each manifest so
  // the unchanged getHeartbeat()/metricsWithValues() below read fresh values.
  const rows = await fetchHeartbeats();
  return getProjects().map((project) => ({
    params: { slug: project.slug },
    props: { project: withHeartbeat(project, rows) },
  }));
}

interface Props {
  project: Manifest;
}
const { project } = Astro.props;

// Each project's case study (sections 2–9) lives beside its manifest as MDX.
const studies = import.meta.glob<{ Content: any }>('/projects/*/case-study.mdx');
const importer = studies[`/projects/${project.slug}/case-study.mdx`];
if (!importer) {
  throw new Error(
    `Missing case study: projects/${project.slug}/case-study.mdx (required by §4.3).`,
  );
}
const { Content } = await importer();

const ctaVerb = {
  embed: 'Watch it live',
  launch: 'Use it live',
  video: 'Watch the walkthrough',
  'watch-only': 'Read the committee’s last debate',
}[project.demo.type];

const accent = project.accent_hex;
const hb = getHeartbeat(project);
const metrics = metricsWithValues(project);
const started = new Date(`${project.started}-01T00:00:00`).toLocaleDateString(
  'en-US',
  { month: 'short', year: 'numeric' },
);
---

<BaseLayout title={project.name} description={project.tagline} accent={accent}>
  <article class="case-study">
    <!-- 01 · Hero -->
    <header class="hero wrap">
      <a href="/#systems" class="back mono">← all systems</a>
      <div class="hero-badges">
        <StatusBadge status={project.status} maturity={project.maturity} />
        <span class="started mono">since {started}</span>
      </div>
      <h1>{project.name}</h1>
      <p class="tagline">{project.tagline}</p>

      <div class="hero-beat">
        <span
          class:list={[
            'ci-heartbeat-dot',
            { 'ci-heartbeat-dot--stale': hb.state === 'stale' },
            { 'ci-heartbeat-dot--awaiting': hb.state === 'awaiting' },
          ]}
          aria-hidden="true"></span>
        <span class:list={['hb-label mono', { awaiting: hb.state === 'awaiting' }]}>
          {hb.label}
        </span>
      </div>

      {
        metrics.length > 0 && (
          <div class="hero-metrics">
            {metrics.map((m) => (
              <div class="hero-metric">
                <span class="hm-value mono" data-metric-key={m.key}>
                  {m.value}
                </span>
                <span class="hm-label mono">{m.label}</span>
              </div>
            ))}
          </div>
        )
      }

      <a class="cta" href="#live">{ctaVerb} →</a>

      <ManifestPanel manifest={project} />
    </header>

    <div class="wrap body">
      <Content />
    </div>
  </article>
</BaseLayout>

<style>
  .hero {
    padding-top: 2.5rem;
    padding-bottom: 1rem;
  }
  .back {
    display: inline-block;
    font-size: 0.78rem;
    color: var(--fg-dim);
    text-decoration: none;
    margin-bottom: 1.5rem;
  }
  .back:hover {
    color: var(--fg);
  }
  .hero-badges {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 1rem;
  }
  .started {
    font-size: 0.72rem;
    color: var(--fg-dim);
  }
  .hero h1 {
    margin: 0;
    font-size: clamp(2.2rem, 5vw, 3.4rem);
  }
  .tagline {
    margin: 0.85rem 0 0;
    color: var(--faint);
    font-size: 1.15rem;
    font-style: italic;
    max-width: 60ch;
  }
  .hero-beat {
    display: flex;
    align-items: center;
    gap: 11px;
    margin-top: 1.5rem;
  }
  .hb-label {
    font-size: 0.8125rem;
    color: var(--stale-text);
  }
  .hb-label.awaiting {
    font-style: italic;
  }
  .hero-metrics {
    display: flex;
    flex-wrap: wrap;
    gap: 2.5rem;
    margin-top: 2rem;
  }
  .hero-metric {
    display: flex;
    flex-direction: column;
  }
  .hm-value {
    font-size: 1.75rem;
    color: var(--accent);
    line-height: 1;
  }
  .hm-label {
    font-size: 0.7rem;
    letter-spacing: 0.04em;
    color: var(--muted);
    margin-top: 0.4rem;
  }
  .cta {
    display: inline-block;
    margin-top: 2rem;
    font-family: var(--font-mono);
    font-size: 0.9rem;
    color: var(--on-accent);
    background: var(--accent);
    text-decoration: none;
    padding: 0.6rem 1.1rem;
    border-radius: 0.4rem;
    font-weight: 600;
  }
  .cta:hover {
    filter: brightness(1.08);
  }
  .body {
    margin-top: 1rem;
  }
</style>
