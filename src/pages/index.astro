---
import BaseLayout from '@layouts/BaseLayout.astro';
import ProjectCard from '@components/ProjectCard.astro';
import { getProjects } from '@lib/manifests';

const projects = getProjects();
const liveCount = projects.filter((p) => p.status === 'live').length;
---

<BaseLayout title="Compound Interests">
  <section class="hero wrap">
    <p class="kicker">Compound Interests · Systems that compound</p>
    <h1 class="hero-name">Chris Liquin</h1>
    <p class="hero-tag">I build and run AI systems.</p>
    <p class="hero-lede">
      A personal AI lab. Each system runs itself, narrates itself, and gets
      better from its own logged data — catalogued and run live here, so the
      discipline is proven rather than asserted.
    </p>
    <div class="hero-beat">
      <span class="ci-heartbeat-dot" aria-hidden="true"></span>
      <span class="beat-count mono">{liveCount}&nbsp;live&nbsp;·&nbsp;{projects.length}&nbsp;catalogued</span>
      <span class="beat-clock mono">·&nbsp;<span data-utc-clock>--:--:--Z</span></span>
    </div>
  </section>

  <section id="systems" class="systems wrap">
    <div class="systems-head">
      <h2>The systems</h2>
      <span class="systems-count mono">{projects.length} catalogued</span>
    </div>
    <div class="grid">
      {projects.map((p) => <ProjectCard project={p} />)}
    </div>
  </section>
</BaseLayout>

<script is:inline>
  // Heartbeat timestamp — current UTC time, refreshed every second (DS §3).
  // It's the live "now" readout, not a freshness claim; per-card dots show real
  // per-system state.
  (function () {
    const pad = (n) => String(n).padStart(2, '0');
    const els = document.querySelectorAll('[data-utc-clock]');
    function tick() {
      const d = new Date();
      const t =
        pad(d.getUTCHours()) +
        ':' +
        pad(d.getUTCMinutes()) +
        ':' +
        pad(d.getUTCSeconds()) +
        'Z';
      els.forEach((el) => (el.textContent = t));
    }
    tick();
    setInterval(tick, 1000);
  })();
</script>

<style>
  .hero {
    padding-top: 72px;
    padding-bottom: 56px;
    border-bottom: 1px solid var(--border);
  }
  .kicker {
    margin: 0 0 20px;
  }
  .hero-name {
    margin: 0;
    font-size: clamp(2.6rem, 7vw, 3.75rem); /* up to 60px */
    font-weight: 600;
    letter-spacing: -0.03em;
    line-height: 1;
    color: var(--text);
  }
  .hero-tag {
    margin: 16px 0 0;
    font-size: 1.125rem; /* 18px */
    font-style: italic;
    color: var(--faint);
  }
  .hero-lede {
    margin: 22px 0 0;
    max-width: 58ch;
    font-size: 0.9375rem; /* 15px */
    line-height: 1.65;
    color: var(--body);
  }
  .hero-beat {
    display: flex;
    align-items: center;
    gap: 11px;
    margin-top: 30px;
  }
  .beat-count {
    font-size: 0.8125rem; /* 13px */
    color: var(--body);
  }
  .beat-clock {
    font-size: 0.8125rem;
    color: var(--muted);
  }
  .systems {
    padding-top: 48px;
    padding-bottom: 64px;
  }
  .systems-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    margin-bottom: 24px;
  }
  .systems-head h2 {
    margin: 0;
    font-size: 1.375rem; /* 22px */
  }
  .systems-count {
    font-size: 0.6875rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--muted);
  }
  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(min(100%, 280px), 1fr));
    gap: 20px;
  }
</style>
