---
import BaseLayout from '@layouts/BaseLayout.astro';
import { getProjects } from '@lib/manifests';

// Aggregate the pattern tags declared across every manifest (§4.4).
const projects = getProjects();
const index = new Map<string, string[]>();
for (const p of projects) {
  for (const tag of p.patterns) {
    if (!index.has(tag)) index.set(tag, []);
    index.get(tag)!.push(p.name);
  }
}
const patterns = [...index.entries()].sort((a, b) => b[1].length - a[1].length);
---

<BaseLayout title="Patterns" description="The reusable AI patterns that power every system in the portfolio.">
  <section class="wrap head">
    <p class="kicker">Patterns</p>
    <h1>Patterns used across the portfolio.</h1>
    <p class="sub">
      These tags are pulled from every project manifest. The full library with
      per-pattern write-ups lands in P1 polish (§4.4).
    </p>
  </section>

  <section class="wrap grid">
    {
      patterns.map(([tag, names]) => (
        <div class="pattern">
          <code>{tag}</code>
          <span class="users">{names.join(' · ')}</span>
        </div>
      ))
    }
  </section>
</BaseLayout>

<style>
  .head {
    padding-top: 4rem;
  }
  .head h1 {
    font-size: clamp(2rem, 5vw, 3rem);
    margin: 0.5rem 0 0;
  }
  .sub {
    color: var(--fg-muted);
    max-width: 56ch;
    margin-top: 1rem;
  }
  .grid {
    margin-top: 2.5rem;
    display: grid;
    gap: 0.75rem;
  }
  .pattern {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 0.5rem 1rem;
    padding: 0.85rem 0;
    border-bottom: 1px solid var(--line-soft);
  }
  .pattern code {
    color: var(--accent);
    font-size: 0.95rem;
  }
  .users {
    color: var(--fg-dim);
    font-size: 0.85rem;
  }
</style>
