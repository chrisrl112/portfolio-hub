---
// Parent design system fonts (ph-33) — Google/OFL, self-hosted via @fontsource.
// Variable axes cover every weight the DS calls for (Space Grotesk 400–700,
// Inter 400–600, JetBrains Mono 400–700). Imported before global.css so the
// --font-* tokens resolve to loaded faces.
import '@fontsource-variable/space-grotesk';
import '@fontsource-variable/inter';
import '@fontsource-variable/jetbrains-mono';
import '../styles/global.css';
import Wordmark from '@components/brand/Wordmark.astro';
import CompoundingMark from '@components/brand/CompoundingMark.astro';

interface Props {
  title: string;
  description?: string;
  accent?: string;
}

const {
  title,
  description = 'Compound Interests — a catalogue of the AI systems I build, with live demos.',
  accent,
} = Astro.props;

const fullTitle =
  title === 'Compound Interests' ? title : `${title} · Compound Interests`;

// Project pages set a sub-brand --accent (accent_hex). On the light theme, pick
// readable text for fills on that accent by its relative luminance so green /
// amber / blue CTAs and LIVE chips stay legible. Parent pages use the :root ink
// accent (--on-accent already light there).
function onAccentFor(hex: string): string {
  const h = hex.replace('#', '');
  if (h.length !== 6) return '#f7f8f8';
  const [r, g, b] = [0, 2, 4].map((i) => parseInt(h.slice(i, i + 2), 16) / 255);
  const lum = 0.2126 * r + 0.7152 * g + 0.0722 * b;
  return lum > 0.5 ? '#0b0c0e' : '#f7f8f8';
}
const bodyStyle = accent
  ? `--accent: ${accent}; --on-accent: ${onAccentFor(accent)}; --mark-lg: ${accent}`
  : undefined;

const year = new Date().getUTCFullYear();
---

<!doctype html>
<html lang="en" data-theme="light">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
  </head>
  <body style={bodyStyle}>
    <header class="site-header">
      <div class="wrap header-inner">
        <a href="/" class="brand">
          <Wordmark markSize={24} />
        </a>
        <nav class="site-nav mono">
          <a href="/#systems" class="active">Systems</a>
          <a href="/patterns">Patterns</a>
          <a href="/about">About</a>
        </nav>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer class="site-footer">
      <div class="wrap footer-inner">
        <span class="footer-mark">
          <CompoundingMark size={20} title="Compound Interests" />
          <span class="footer-name mono">Compound Interests</span>
        </span>
        <span class="footer-tag mono">systems that compound · {year}</span>
      </div>
    </footer>

    <style>
      .site-header {
        border-bottom: 1px solid var(--border);
      }
      .header-inner {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding-block: 20px;
      }
      .brand {
        display: inline-flex;
        align-items: center;
        text-decoration: none;
      }
      .site-nav {
        display: flex;
        gap: 26px;
        font-size: 0.75rem; /* 12px */
        letter-spacing: 0.08em;
        color: var(--muted);
      }
      .site-nav a {
        text-decoration: none;
        color: var(--muted);
      }
      .site-nav a.active,
      .site-nav a:hover {
        color: var(--text);
      }
      .site-footer {
        margin-top: 4rem;
        border-top: 1px solid var(--border);
      }
      .footer-inner {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding-block: 28px;
      }
      .footer-mark {
        display: inline-flex;
        align-items: center;
        gap: 10px;
      }
      .footer-name {
        font-size: 0.6875rem; /* 11px */
        letter-spacing: 0.14em;
        text-transform: uppercase;
        color: var(--muted);
      }
      .footer-tag {
        font-size: 0.6875rem;
        letter-spacing: 0.09em;
        color: var(--stale-text);
      }
    </style>
  </body>
</html>
