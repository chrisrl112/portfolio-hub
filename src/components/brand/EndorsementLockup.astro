---
/**
 * Endorsement lockup (ph-35): ~26px compounding mark + "A COMPOUND INTERESTS
 * SYSTEM" in mono 12px, +1.5px tracking, uppercase, slate-400. Placement rule
 * (DS): site footer + OG; every sub-brand page carries it.
 */
import CompoundingMark from './CompoundingMark.astro';
---

<span class="endorse">
  <CompoundingMark size={26} title="Compound Interests" />
  <span class="endorse-text">A Compound Interests system</span>
</span>

<style>
  .endorse {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
  }
  .endorse-text {
    font-family: var(--font-mono);
    font-size: 0.75rem; /* 12px */
    letter-spacing: 0.125em; /* ~1.5px at 12px */
    text-transform: uppercase;
    color: var(--slate-400);
  }
</style>
