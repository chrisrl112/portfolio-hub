---
/**
 * Compounding mark (primary) — Parent Design System v1 (ph-35).
 * Three squares stepping up and to the right; brightest (top-right) is always
 * ci-bone, middle paper-100, smallest slate-400. Meaning: small inputs
 * compounding into growth. Inline SVG, never raster (DS §Assets).
 * Geometry is the locked 64×64 viewBox spec.
 */
interface Props {
  size?: number;
  /** Accessible label; omit for a decorative mark (aria-hidden). */
  title?: string;
}
const { size = 64, title } = Astro.props;
---

<svg
  class="ci-mark"
  width={size}
  height={size}
  viewBox="0 0 64 64"
  fill="none"
  xmlns="http://www.w3.org/2000/svg"
  role={title ? 'img' : undefined}
  aria-label={title}
  aria-hidden={title ? undefined : 'true'}
>
  {title && <title>{title}</title>}
  <rect x="4" y="42" width="16" height="16" rx="2" fill="#8A8F98"></rect>
  <rect x="22" y="25" width="18" height="18" rx="2" fill="#ECEDEE"></rect>
  <rect x="42" y="6" width="20" height="20" rx="2" fill="#E6E1D5"></rect>
</svg>

<style>
  .ci-mark {
    display: block;
    flex: none;
  }
</style>
