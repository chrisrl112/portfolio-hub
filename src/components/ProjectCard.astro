---
import { computeStaleNote, type Manifest } from '@lib/manifests';
import StatusBadge from '@components/StatusBadge.astro';

interface Props {
  project: Manifest;
}
const { project } = Astro.props;
const headline = project.metrics.slice(0, 2);
const staleNote = computeStaleNote(project.last_heartbeat);
---

<a class="card" href={project.links.page}>
  <div class="card-top">
    <StatusBadge
      status={project.status}
      maturity={project.maturity}
      staleNote={staleNote}
    />
  </div>

  <h3 class="card-name">{project.name}</h3>
  <p class="card-tagline">{project.tagline}</p>

  {
    headline.length > 0 && (
      <div class="card-metrics">
        {headline.map((m) => (
          <div class="card-metric">
            <span class="m-value mono" data-metric-key={m.key}>
              —
            </span>
            <span class="m-label">{m.label}</span>
          </div>
        ))}
      </div>
    )
  }

  <span class="card-cta">View case study →</span>
</a>

<style>
  .card {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
    padding: 1.4rem;
    text-decoration: none;
    background: var(--ink-850);
    border: 1px solid var(--line);
    border-radius: 0.6rem;
    overflow: hidden;
    transition:
      transform 0.18s ease,
      border-color 0.18s ease;
  }
  .card::before {
    content: '';
    position: absolute;
    inset: 0 auto 0 0;
    width: 3px;
    background: var(--accent);
    opacity: 0.85;
  }
  .card:hover {
    transform: translateY(-3px);
    border-color: color-mix(in srgb, var(--accent) 55%, var(--line));
  }
  .card-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .card-name {
    margin: 0;
    font-size: 1.4rem;
  }
  .card-tagline {
    margin: 0;
    color: var(--fg-muted);
    font-size: 0.92rem;
  }
  .card-metrics {
    display: flex;
    gap: 1.5rem;
    margin-top: 0.25rem;
    padding-top: 0.85rem;
    border-top: 1px solid var(--line-soft);
  }
  .card-metric {
    display: flex;
    flex-direction: column;
  }
  .m-value {
    font-size: 1.15rem;
    font-weight: 600;
    color: var(--accent);
  }
  .m-label {
    font-size: 0.72rem;
    color: var(--fg-dim);
  }
  .card-cta {
    margin-top: auto;
    padding-top: 0.5rem;
    font-family: var(--font-mono);
    font-size: 0.78rem;
    color: var(--fg-dim);
  }
  .card:hover .card-cta {
    color: var(--accent);
  }
</style>
