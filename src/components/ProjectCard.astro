---
import {
  getHeartbeat,
  metricsWithValues,
  type Manifest,
} from '@lib/manifests';
import StatusBadge from '@components/StatusBadge.astro';

interface Props {
  project: Manifest;
}
const { project } = Astro.props;
const metrics = metricsWithValues(project);
const hb = getHeartbeat(project);
const ctaVerb = project.demo.type === 'launch' ? 'Open the demo' : 'View case study';
---

<a class="card" href={project.links.page} data-capsule-slug={project.slug}>
  <div class="card-body">
    <StatusBadge status={project.status} maturity={project.maturity} />

    <h3 class="card-name">{project.name}</h3>
    <p class="card-tagline">{project.tagline}</p>

    {
      metrics.length > 0 && (
        <div class="card-metrics">
          {metrics.map((m) => (
            <div class="card-metric">
              <span class="m-value mono" data-metric-key={m.key}>
                {m.value}
              </span>
              <span class="m-label mono">{m.label}</span>
            </div>
          ))}
        </div>
      )
    }

    <div class:list={['card-foot', { 'has-rule': metrics.length === 0 }]}>
      <span
        class:list={[
          'card-dot',
          { 'card-dot--stale': hb.state === 'stale' },
          { 'card-dot--awaiting': hb.state === 'awaiting' },
        ]}
        aria-hidden="true"></span>
      <span class:list={['hb-label mono', { awaiting: hb.state === 'awaiting' }]}>
        {hb.label}
      </span>
      <span class="card-cta mono">{ctaVerb} →</span>
    </div>
  </div>
</a>

<script>
  // Delegated capsule_click (ph-27). The whole tile is the <a>; a delegated
  // listener covers every card with one binding. Astro hoists this module once
  // per page even though ProjectCard renders N times. The Vercel beacon uses
  // sendBeacon, so the event survives the click-through navigation.
  import { trackCapsuleClick } from '@lib/analytics';
  document.addEventListener('click', (e) => {
    const target = e.target as HTMLElement | null;
    const a = target?.closest?.('a[data-capsule-slug]');
    const slug = a?.getAttribute('data-capsule-slug');
    if (slug) trackCapsuleClick(slug);
  });
</script>

<style>
  /* Locked home card (round 2): panel fill, 3px top accent keyline, hairline
     border — NO left-rule bar (explicit anti-pattern). */
  .card {
    display: flex;
    flex-direction: column;
    text-decoration: none;
    background: var(--panel);
    border: 1px solid var(--border);
    border-top: 3px solid var(--card-accent);
    border-radius: var(--radius-card);
    transition: border-color 0.18s ease, transform 0.18s ease;
  }
  .card:hover {
    transform: translateY(-2px);
    border-color: color-mix(in srgb, var(--accent) 45%, var(--border));
    border-top-color: var(--accent);
  }
  .card-body {
    display: flex;
    flex-direction: column;
    height: 100%;
    padding: 22px;
  }
  .card-name {
    margin: 20px 0 0;
    font-size: 1.1875rem; /* 19px */
    color: var(--text);
    letter-spacing: -0.01em;
  }
  .card-tagline {
    margin: 8px 0 0;
    font-size: 0.8125rem; /* 13px */
    line-height: 1.55;
    color: var(--faint);
  }
  .card-metrics {
    display: flex;
    gap: 28px;
    margin-top: 20px;
    padding-top: 18px;
    border-top: 1px solid var(--border);
  }
  .card-metric {
    display: flex;
    flex-direction: column;
  }
  .m-value {
    font-size: 1.375rem; /* 22px */
    color: var(--accent);
    line-height: 1;
  }
  .m-label {
    font-size: 0.625rem; /* 10px */
    letter-spacing: 0.04em;
    color: var(--muted);
    margin-top: 4px;
  }
  .card-foot {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-top: auto;
    padding-top: 18px;
  }
  .card-foot.has-rule {
    margin-top: auto;
    padding-top: 20px;
    border-top: 1px solid var(--border);
  }
  /* heartbeat dot — card scale (7px), reuses the global ciPulse keyframe */
  .card-dot {
    width: 7px;
    height: 7px;
    border-radius: var(--radius-pill);
    background: var(--accent);
    flex: none;
    animation: ciPulse var(--pulse-duration) ease-out infinite;
  }
  .card-dot--stale {
    background: var(--dot-empty);
    animation: none;
  }
  .card-dot--awaiting {
    background: transparent;
    border: 1px solid var(--dot-empty);
    box-sizing: border-box;
    animation: none;
  }
  .hb-label {
    font-size: 0.6875rem; /* 11px */
    color: var(--stale-text);
  }
  .hb-label.awaiting {
    font-style: italic;
  }
  .card-cta {
    margin-left: auto;
    font-size: 0.6875rem; /* 11px */
    color: var(--accent);
  }
</style>
