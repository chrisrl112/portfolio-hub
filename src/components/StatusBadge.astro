---
import type { ManifestStatus } from '@lib/manifests';
import MaturityMeter from '@components/MaturityMeter.astro';

interface Props {
  status: ManifestStatus;
  /** When provided, the maturity dots render inside the keystone pill. */
  maturity?: number;
  /**
   * Optional staleness-honesty note (e.g. "No heartbeat in 5d"), rendered
   * beside the pill when present (§3.3 / §9.4). The dormant auto-flip is
   * computed upstream from heartbeat age; this only displays what it is handed.
   */
  staleNote?: string;
}
const { status, maturity, staleNote } = Astro.props;
---

<span class="badge-wrap">
  <span class="badge">
    <span class:list={['chip', `chip-${status}`]}>{status}</span>
    {maturity != null && <MaturityMeter maturity={maturity} />}
  </span>
  {staleNote && (
    <span class="stale" title="Staleness honesty (§3.3)">{staleNote}</span>
  )}
</span>

<style>
  /* Keystone status/maturity badge — Parent Design System v1 (ph-34).
     One ink-900 pill, mono throughout; ci-bone is the only signal color. */
  .badge-wrap {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
  }
  .badge {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    background: var(--ink-900);
    border-radius: var(--radius-pill);
    padding: 0.5rem 0.9rem;
    font-family: var(--font-mono);
  }
  .chip {
    font-family: var(--font-mono);
    font-size: 0.6875rem; /* 11px */
    font-weight: 700;
    letter-spacing: 0.09em;
    text-transform: uppercase;
    padding: 0.19rem 0.56rem; /* ~3px 9px */
    border-radius: var(--radius-chip);
    border: 1px solid transparent; /* keep all variants the same height */
    white-space: nowrap;
  }
  /* LIVE — filled bone, ink text. BETA — bone outline. CONCEPT — dotted slate.
     dormant / retired are not a live signal → muted slate, never bone. */
  .chip-live {
    background: var(--accent);
    color: var(--on-accent);
  }
  .chip-beta {
    color: var(--accent);
    border-color: var(--accent);
  }
  .chip-concept {
    color: var(--slate-400);
    border-style: dotted;
    border-color: var(--slate-400);
  }
  .chip-dormant {
    color: var(--slate-400);
    border-color: var(--slate-600);
  }
  .chip-retired {
    color: var(--slate-500);
    border-color: var(--slate-600);
  }
  .stale {
    font-family: var(--font-mono);
    font-size: 0.66rem;
    font-style: italic;
    letter-spacing: 0.04em;
    color: var(--slate-400);
  }
</style>
