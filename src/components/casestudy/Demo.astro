---
import type { Demo, DemoType } from '@lib/manifests';
import GrowroomEmbed from '@components/casestudy/GrowroomEmbed.astro';
import { GROWROOM_SLUG, GROWROOM_CHANNEL } from '@lib/growroom';

interface Props {
  demo: Demo;
  /** Manifest slug — carried on the demo_start analytics event (ph-27). */
  slug: string;
}
const { demo, slug } = Astro.props;

// ph-43: the Growroom embed is the first real `embed` surface. Render the live
// "living window" only when it's the Growroom AND a channel is configured;
// otherwise (unconfigured, or any other embed) fall back to the honest
// placeholder below (State C — dormant-by-default, never a broken player).
const showGrowroom = demo.type === 'embed' && slug === GROWROOM_SLUG && !!GROWROOM_CHANNEL;

const verb: Record<DemoType, string> = {
  embed: 'Watch it live',
  launch: 'Use it live',
  video: 'Watch the walkthrough',
  'watch-only': 'Watch the process',
};
const note: Record<DemoType, string> = {
  embed: 'Live Twitch embed — degrades to the latest timelapse when the stream is offline.',
  launch: 'Public read-only demo mode (no real user data).',
  video: '60–90s screen capture stands in until a live surface exists.',
  'watch-only': 'Read-only dashboard + committee transcript gallery.',
};
---

<div class="demo" data-demo-root data-demo-slug={slug} data-demo-type={demo.type}>
  {
    showGrowroom ? (
      <GrowroomEmbed />
    ) : (
      <>
        <div class="demo-head">
          <span class="demo-type mono">{demo.type}</span>
          <span class="demo-verb">{verb[demo.type]}</span>
        </div>
        <p class="demo-note">{note[demo.type]}</p>
        <div class="demo-meta mono">
          {/* The live target URL is intentionally not printed: until P2/P4 wire the
              real embed, a manifest demo.url may be a placeholder (e.g. an unfilled
              Twitch channel) or just an internal anchor. Showing it would leak a
              non-working target on a credibility-first page (§9.4, ph-22 QA). */}
          {demo.fallback && <span>fallback: {demo.fallback}</span>}
          <span class="pending">live surface wires up post-MVP (P2 / P4)</span>
        </div>
      </>
    )
  }
</div>

<script>
  // demo_start (ph-27) — fires once per page on the real "start" signal for the
  // demo's type. Bindings are future-proof: until the live embed/video/launch
  // surface lands (P2/P4) those elements don't exist yet, so nothing fires for
  // those types — no false "start". watch-only fires when the read-only artifact
  // scrolls into view (its only "start" affordance).
  import { trackDemoStart, type DemoType } from '@lib/analytics';

  const root = document.querySelector<HTMLElement>('[data-demo-root]');
  if (root) {
    const slug = root.dataset.demoSlug ?? '';
    const type = root.dataset.demoType as DemoType;
    let fired = false;
    const fire = () => {
      if (fired || !slug) return;
      fired = true;
      trackDemoStart(slug, type);
    };

    if (type === 'launch') {
      root.querySelector('a')?.addEventListener('click', fire);
    } else if (type === 'video') {
      root.querySelector('video')?.addEventListener('play', fire, { once: true });
    } else if (type === 'embed') {
      root.querySelector('iframe')?.addEventListener('load', fire, { once: true });
    } else {
      // watch-only: "start" = the read-only artifact scrolled into view.
      const obs = new IntersectionObserver(
        (entries) => {
          if (entries.some((en) => en.isIntersecting)) {
            fire();
            obs.disconnect();
          }
        },
        { threshold: 0.4 },
      );
      obs.observe(root);
    }
  }
</script>

<style>
  .demo {
    border: 1px dashed color-mix(in srgb, var(--accent) 45%, var(--line));
    border-radius: 0.6rem;
    padding: 1.25rem;
    background: color-mix(in srgb, var(--accent) 6%, var(--ink-850));
  }
  .demo-head {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }
  .demo-type {
    font-size: 0.68rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--accent);
    border: 1px solid color-mix(in srgb, var(--accent) 45%, var(--line));
    border-radius: 0.3rem;
    padding: 0.15rem 0.5rem;
  }
  .demo-verb {
    font-family: var(--font-serif);
    font-size: 1.2rem;
  }
  .demo-note {
    margin: 0.6rem 0 0;
    color: var(--fg-muted);
    font-size: 0.92rem;
  }
  .demo-meta {
    margin-top: 0.85rem;
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem 1.1rem;
    font-size: 0.72rem;
    color: var(--fg-dim);
  }
  .pending {
    color: var(--accent);
    opacity: 0.8;
  }
</style>
