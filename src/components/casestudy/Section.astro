---
interface Props {
  n: string;
  title: string;
  id?: string;
}
const { n, title, id } = Astro.props;
---

<section class="cs-section" id={id}>
  <header class="cs-head">
    <span class="cs-n mono">{n}</span>
    <h2>{title}</h2>
  </header>
  <div class="cs-body">
    <slot />
  </div>
</section>

<style>
  .cs-section {
    padding-block: 2.5rem;
    border-top: 1px solid var(--line-soft);
  }
  .cs-head {
    display: flex;
    align-items: baseline;
    gap: 0.85rem;
    margin-bottom: 1.25rem;
  }
  .cs-n {
    font-size: 0.78rem;
    color: var(--accent);
    letter-spacing: 0.1em;
  }
  .cs-head h2 {
    margin: 0;
    font-size: 1.65rem;
  }
</style>
