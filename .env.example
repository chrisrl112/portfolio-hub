# Portfolio Hub — local env (ph-5 heartbeat live layer).
# Copy to `.env` and fill from Supabase → Project Settings → API.
# Both are PUBLIC, read-only-safe ONLY because RLS denies all anon writes
# (supabase/heartbeats.sql §3). The site reads these at BUILD time.

PUBLIC_SUPABASE_URL=
PUBLIC_SUPABASE_ANON_KEY=

# NEVER put SUPABASE_SERVICE_ROLE_KEY here or anywhere in this repo. It lives
# ONLY in each spoke runtime's secret store and is wired in ph-23 / ph-24.
